rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'super_admin';
    }

    function isSameHospital(hospitalId) {
      return isAuthenticated() && (getUserData().hospitalId == hospitalId || isSuperAdmin());
    }

    function hasRole(role) {
      return isAuthenticated() && (getUserData().role == role || isSuperAdmin());
    }

    // Rules for users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || getUserData().hospitalId == resource.data.hospitalId);
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || hasRole('hospital_admin') || isSuperAdmin());
      allow delete: if isAuthenticated() && (hasRole('hospital_admin') || isSuperAdmin());
    }

    // Rules for hospitals collection
    match /hospitals/{hospitalId} {
      allow read: if isAuthenticated() && (getUserData().hospitalId == hospitalId || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    // Rules for patients collection
    match /patients/{patientId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        (getUserData().hospitalId == resource.data.hospitalId && (
          getUserData().role == 'hospital_admin' || 
          getUserData().role == 'doctor' || 
          getUserData().role == 'nurse' ||
          (getUserData().role == 'caregiver' && patientId in getUserData().assignedPatients)
        ))
      );
      
      allow create: if isAuthenticated() && (
        hasRole('hospital_admin') || 
        hasRole('nurse')
      );
      
      allow update: if isAuthenticated() && (
        hasRole('hospital_admin') || 
        hasRole('doctor') || 
        hasRole('nurse')
      );
      
      allow delete: if isAuthenticated() && (
        hasRole('hospital_admin')
      );
    }

    // Rules for alerts collection
    match /alerts/{alertId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        (getUserData().hospitalId == resource.data.hospitalId)
      );
      
      allow create: if isAuthenticated(); // Allowed for telemetry updates/local sensors
      allow update: if isAuthenticated() && (
        hasRole('hospital_admin') || 
        hasRole('doctor') || 
        hasRole('nurse')
      );
      allow delete: if isAuthenticated() && (
        hasRole('hospital_admin')
      );
    }

    // Rules for cameras collection
    match /cameras/{cameraId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        (getUserData().hospitalId == resource.data.hospitalId)
      );
      allow write: if isAuthenticated() && (
        hasRole('hospital_admin')
      );
    }

    // Rules for vitals_history collection
    match /vitals_history/{vitalId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        (getUserData().hospitalId == resource.data.hospitalId)
      );
      allow create: if isAuthenticated() && (
        hasRole('hospital_admin') || 
        hasRole('doctor') || 
        hasRole('nurse')
      );
      allow update, delete: if isAuthenticated() && (
        hasRole('hospital_admin')
      );
    }
  }
}
